# Dependencies
node_modules/
.pnp.*
.yarn/

# Build outputs
dist/
dist-electron/
out/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.history/

# Temp files
*.tmp
*.bak
*~

# Env
.env
.env.local
.env.*.local
!.env.example

# Electron-builder caches
.cache/
*.dmg
*.exe
*.msi
*.AppImage
*.deb
*.snap

# F010: generated icon placeholder (regenerated each build via scripts/gen-icon.mjs)
resources/icon.png
resources/icon.ico
resources/icon.icns
resources/.icon-*/

# KodaX Space runtime data (should be in ~/.kodax/space/, never committed)
.kodax/
**/.kodax-space-test-data/

# Vite / other bundler caches
.vite/
.turbo/
.parcel-cache/
.npm/

# Coverage
coverage/
.nyc_output/

# Native build artifacts (NAPI crates, future features)
target/
*.node
!packages/native/**/index.d.ts
.claude/

# Playwright test outputs (e2e/ scripts checked in; runtime artifacts not)
test-results/
.agent/
.repointel/
playwright-report/

# Local scratch / working files (asset generation previews, vite-preview logs, etc.)
# Final assets are committed under apps/desktop/renderer/src/assets/; tmp/ is scratch only.
tmp/
